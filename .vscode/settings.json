{
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.format.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "markdown",
    "css"
  ],
  "json.schemas": [
    {
      "fileMatch": ["packages/game/data/*/manifest.json"],
      "url": "./packages/game/data/schema/manifest.schema.json"
    },
    {
      "fileMatch": ["packages/game/data/*/skills.json"],
      "url": "./packages/game/data/schema/skills.schema.json"
    },
    {
      "fileMatch": ["packages/game/data/*/traits.json"],
      "url": "./packages/game/data/schema/traits.schema.json"
    },
    {
      "fileMatch": ["packages/game/data/*/origins.json"],
      "url": "./packages/game/data/schema/origins.schema.json"
    },
    {
      "fileMatch": ["packages/game/data/*/careers.json"],
      "url": "./packages/game/data/schema/careers.schema.json"
    }
  ]
}
