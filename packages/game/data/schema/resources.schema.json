{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resource Definitions",
  "description": "Mineable and tradeable resources.",
  "type": "array",
  "items": {
    "type": "object",
    "description": "A single resource definition.",
    "required": ["id", "name_key", "description_key"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for this resource."
      },
      "name_key": {
        "type": "string",
        "description": "i18n key for the display name."
      },
      "description_key": {
        "type": "string",
        "description": "i18n key for the description."
      },
      "tags": {
        "type": "array",
        "description": "Tag IDs.",
        "items": {
          "type": "string"
        },
        "default": []
      }
    }
  }
}
