{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Formation Definitions",
  "description": "Geological formations made of matrix rock and embedded resources.",
  "type": "array",
  "items": {
    "type": "object",
    "description": "A formation definition.",
    "required": ["id", "name_key", "description_key", "matrix_resource"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for this formation."
      },
      "name_key": {
        "type": "string",
        "description": "i18n key for the display name."
      },
      "description_key": {
        "type": "string",
        "description": "i18n key for the description."
      },
      "matrix_resource": {
        "type": "string",
        "description": "Resource ID for the matrix rock."
      },
      "embedded_resources": {
        "type": "array",
        "description": "Resources mixed into the matrix rock. Sum of all max_grade values must be <= 1.0.",
        "default": [],
        "items": {
          "type": "object",
          "required": ["resource", "probability", "min_grade", "max_grade"],
          "additionalProperties": false,
          "properties": {
            "resource": {
              "type": "string",
              "description": "Resource ID."
            },
            "probability": {
              "type": "number",
              "description": "Chance this resource appears in a generated site (0.0 to 1.0).",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "min_grade": {
              "type": "number",
              "description": "Minimum fraction of site mass this resource can occupy.",
              "minimum": 0.0
            },
            "max_grade": {
              "type": "number",
              "description": "Maximum fraction of site mass this resource can occupy.",
              "minimum": 0.0
            }
          }
        }
      }
    }
  }
}
