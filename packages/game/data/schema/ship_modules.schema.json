{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ship Module Definitions",
  "description": "Components that can be installed on a ship. Each module has a category that determines its fields.",
  "type": "array",
  "items": {
    "discriminator": {
      "propertyName": "category"
    },
    "oneOf": [
      {
        "type": "object",
        "description": "Command bridge. Mandatory, one per ship.",
        "required": ["id", "name_key", "description_key", "category"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "bridge" }
        }
      },
      {
        "type": "object",
        "description": "Ship reactor. Mandatory, one per ship.",
        "required": ["id", "name_key", "description_key", "category"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "reactor" }
        }
      },
      {
        "type": "object",
        "description": "Propulsion engine.",
        "required": [
          "id",
          "name_key",
          "description_key",
          "category",
          "speed",
          "fuel_efficiency"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "engine" },
          "speed": {
            "type": "number",
            "description": "Ship speed.",
            "exclusiveMinimum": 0
          },
          "fuel_efficiency": {
            "type": "number",
            "description": "Fuel efficiency rating.",
            "exclusiveMinimum": 0
          }
        }
      },
      {
        "type": "object",
        "description": "Fuel storage tank.",
        "required": [
          "id",
          "name_key",
          "description_key",
          "category",
          "capacity"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "fuel_tank" },
          "capacity": {
            "type": "number",
            "description": "Fuel capacity in tonnes.",
            "exclusiveMinimum": 0
          }
        }
      },
      {
        "type": "object",
        "description": "Crew quarters. Houses one crew member.",
        "required": ["id", "name_key", "description_key", "category"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "crew_quarters" }
        }
      },
      {
        "type": "object",
        "description": "Cargo hold for mined resources.",
        "required": [
          "id",
          "name_key",
          "description_key",
          "category",
          "capacity"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "cargo_bay" },
          "capacity": {
            "type": "number",
            "description": "Cargo capacity in tonnes.",
            "exclusiveMinimum": 0
          }
        }
      },
      {
        "type": "object",
        "description": "Ship-mounted spectral scanner for asteroid discovery.",
        "required": [
          "id",
          "name_key",
          "description_key",
          "category",
          "sensitivity"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "scanner" },
          "sensitivity": {
            "type": "number",
            "description": "Scanner sensitivity for detection formula.",
            "exclusiveMinimum": 0
          }
        }
      },
      {
        "type": "object",
        "description": "Bay that holds one deployable machine.",
        "required": ["id", "name_key", "description_key", "category"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Unique identifier." },
          "name_key": {
            "type": "string",
            "description": "i18n key for the display name."
          },
          "description_key": {
            "type": "string",
            "description": "i18n key for the description."
          },
          "category": { "const": "machine_bay" }
        }
      }
    ]
  }
}
