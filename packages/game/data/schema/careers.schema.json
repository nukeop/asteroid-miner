{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Career Definitions",
  "description": "Defines pawn careers: what they did professionally before appearing in the game.",
  "type": "array",
  "items": {
    "type": "object",
    "description": "A single career definition.",
    "required": ["id", "name_key", "description_key"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for this career.",
        "examples": ["belt_miner", "navy_pilot", "field_medic"]
      },
      "name_key": {
        "type": "string",
        "description": "i18n key for the display name."
      },
      "description_key": {
        "type": "string",
        "description": "i18n key for the description."
      },
      "skill_bonuses": {
        "type": "array",
        "description": "Starting skill level bonuses granted by this career.",
        "default": [],
        "items": { "$ref": "#/$defs/SkillBonus" }
      }
    }
  },
  "$defs": {
    "SkillBonus": {
      "type": "object",
      "description": "A starting bonus applied to a specific skill.",
      "required": ["id", "amount"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "The skill ID to apply the bonus to."
        },
        "amount": {
          "type": "integer",
          "description": "Number of skill levels to add (positive) or subtract (negative).",
          "examples": [1, 2, -1]
        }
      }
    }
  }
}
